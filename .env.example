# Local PostgreSQL connection string used by Prisma.
# This matches docker-compose.yml and is for local development only.
DATABASE_URL="postgresql://conversational_mcq:conversational_mcq_dev_password@localhost:5432/conversational_mcq?schema=public"

# Use a long random value in real environments. Do not commit real secrets.
SESSION_SECRET="replace-with-at-least-32-random-characters"

# LLM provider configuration. Defaults keep the app fully local and mock-only.
LLM_PROVIDER=mock
LLM_LIVE_CALLS_ENABLED=false

# OpenAI placeholders. Phase 6A does not connect agents to classroom workflows.
# Leave these blank unless you intentionally run the synthetic connectivity test.
OPENAI_API_KEY=""
OPENAI_MODEL_ITEM_PREP=""
OPENAI_MODEL_RESPONSE_COLLECTION=""
OPENAI_MODEL_PROFILING=""
OPENAI_MODEL_PLANNING=""
OPENAI_MODEL_FOLLOWUP=""
OPENAI_MODEL_CONNECTIVITY_TEST=""

# Optional per-agent model controls. Leave blank unless the selected model supports them.
OPENAI_REASONING_EFFORT_ITEM_PREP=""
OPENAI_REASONING_EFFORT_RESPONSE_COLLECTION=""
OPENAI_REASONING_EFFORT_PROFILING=""
OPENAI_REASONING_EFFORT_PLANNING=""
OPENAI_REASONING_EFFORT_FOLLOWUP=""

OPENAI_MAX_OUTPUT_TOKENS_ITEM_PREP=""
OPENAI_MAX_OUTPUT_TOKENS_RESPONSE_COLLECTION=""
OPENAI_MAX_OUTPUT_TOKENS_PROFILING=""
OPENAI_MAX_OUTPUT_TOKENS_PLANNING=""
OPENAI_MAX_OUTPUT_TOKENS_FOLLOWUP=""

OPENAI_REQUEST_TIMEOUT_MS=60000
OPENAI_MAX_RETRIES=2

# Server-side operational LLM usage safeguards.
# These limits are not student-facing labels and are checked only on the backend.
LLM_DAILY_CLASS_CALL_LIMIT=200
LLM_DAILY_CLASS_TOKEN_LIMIT=500000
LLM_DAILY_STUDENT_CALL_LIMIT=25
LLM_DAILY_STUDENT_TOKEN_LIMIT=75000
LLM_SESSION_CALL_LIMIT=20
LLM_SESSION_TOKEN_LIMIT=50000
LLM_AGENT_CALL_LIMIT_PER_SESSION=8

# Cost limits remain optional until a versioned pricing registry is configured.
LLM_COST_WARNING_LIMIT_USD=""
LLM_COST_HARD_LIMIT_USD=""
LLM_USAGE_TIMEZONE=UTC

# Student browser process-event thresholds for local development.
# These are technical debounce/timing defaults, not psychological thresholds.
NEXT_PUBLIC_LONG_PAUSE_MS=120000
NEXT_PUBLIC_INACTIVITY_MS=300000
