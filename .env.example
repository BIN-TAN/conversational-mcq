# Local PostgreSQL connection string used by Prisma.
# This matches docker-compose.yml and is for local development only.
DATABASE_URL="postgresql://conversational_mcq:conversational_mcq_dev_password@localhost:5432/conversational_mcq?schema=public"

# Use a long random value in real environments. Do not commit real secrets.
SESSION_SECRET="replace-with-at-least-32-random-characters"

# LLM provider configuration. Defaults keep the app fully local and mock-only.
LLM_PROVIDER=mock
LLM_LIVE_CALLS_ENABLED=false

# OpenAI placeholders. Leave blank for normal mock-mode development and smoke tests.
# Configure only when intentionally enabling server-side live OpenAI calls.
OPENAI_API_KEY=""
OPENAI_MODEL_ITEM_VERIFICATION=""
OPENAI_MODEL_RESPONSE_COLLECTION=""
OPENAI_MODEL_PROFILING=""
OPENAI_MODEL_PLANNING=""
OPENAI_MODEL_FOLLOWUP=""
OPENAI_MODEL_CONNECTIVITY_TEST=""

# Optional per-agent model controls. Leave blank unless the selected model supports them.
OPENAI_REASONING_EFFORT_ITEM_VERIFICATION=""
OPENAI_REASONING_EFFORT_RESPONSE_COLLECTION=""
OPENAI_REASONING_EFFORT_PROFILING=""
OPENAI_REASONING_EFFORT_PLANNING=""
OPENAI_REASONING_EFFORT_FOLLOWUP=""

OPENAI_MAX_OUTPUT_TOKENS_ITEM_VERIFICATION=""
OPENAI_MAX_OUTPUT_TOKENS_RESPONSE_COLLECTION=""
OPENAI_MAX_OUTPUT_TOKENS_PROFILING=""
OPENAI_MAX_OUTPUT_TOKENS_PLANNING=""
OPENAI_MAX_OUTPUT_TOKENS_FOLLOWUP=""

OPENAI_REQUEST_TIMEOUT_MS=60000
OPENAI_MAX_RETRIES=2

# One deployment instance serves one course. Store database timestamps in UTC,
# but display/parse assessment availability in this IANA course timezone.
COURSE_TIMEZONE=America/Edmonton

# Classroom workflow defaults. Keep these false for normal classroom use.
# Development smoke tests may temporarily override them server-side.
DEVELOPMENT_ACTIVE_SESSION_CONTROLS_ENABLED=false
ALLOW_MANUAL_REVIEW_STUDENT_STARTS=false

# Server-side operational LLM usage safeguards.
# These limits are not student-facing labels and are checked only on the backend.
LLM_DAILY_CLASS_CALL_LIMIT=200
LLM_DAILY_CLASS_TOKEN_LIMIT=500000
LLM_DAILY_STUDENT_CALL_LIMIT=25
LLM_DAILY_STUDENT_TOKEN_LIMIT=75000
LLM_SESSION_CALL_LIMIT=20
LLM_SESSION_TOKEN_LIMIT=50000
LLM_AGENT_CALL_LIMIT_PER_SESSION=8

# Cost limits remain optional until a versioned pricing registry is configured.
LLM_COST_WARNING_LIMIT_USD=""
LLM_COST_HARD_LIMIT_USD=""
LLM_USAGE_TIMEZONE=UTC

# Follow-up Agent context-window safeguards.
# These are technical limits for provider input and message size, not pedagogical turn caps.
FOLLOWUP_CONTEXT_MAX_TURNS=24
FOLLOWUP_MESSAGE_MAX_CHARS=6000
FOLLOWUP_CONTEXT_MAX_CHARS=50000
FOLLOWUP_SUBSTANTIVE_TURNS_BEFORE_UPDATE=3

# Phase 8A guarded operational agent integration.
# Keep disabled for ordinary local/classroom-style use. Enabling this switch does
# not enable live OpenAI calls; Phase 8A still permits only mock-mode local
# integration unless a later approved phase changes classroom live-call policy.
OPERATIONAL_AGENT_INTEGRATION_ENABLED=false
OPERATIONAL_AGENT_INTEGRATION_EVAL_EVIDENCE_REQUIRED=true
OPERATIONAL_AGENT_INTEGRATION_APPROVED_TARGETED_RUN_ID=evr_20260624_bltzgtq

# Initial-administration free-text Response Collection Agent safeguards.
# Mock response-collection calls are disabled in ordinary student workflow unless this is explicitly true.
ALLOW_MOCK_RESPONSE_COLLECTION_IN_STUDENT_WORKFLOW=false
INITIAL_CHAT_MESSAGE_MAX_CHARS=6000
RESPONSE_COLLECTION_CONTEXT_MAX_TURNS=12
RESPONSE_COLLECTION_CONTEXT_MAX_CHARS=20000

# Async workflow job safeguards for automatic assessment mode.
WORKFLOW_JOB_MAX_ATTEMPTS=3
WORKFLOW_JOB_BASE_RETRY_MS=5000
WORKFLOW_JOB_MAX_RETRY_MS=300000
WORKFLOW_JOB_LEASE_TIMEOUT_MS=300000
WORKFLOW_JOB_POLL_INTERVAL_MS=2000

# Phase 7E2A internal evaluation harness defaults.
# Evaluation live calls are separate from classroom live calls. Keep disabled unless
# intentionally running the CLI-only paid canary after setting OPENAI_API_KEY locally.
EVAL_PROVIDER=mock
EVAL_LIVE_CALLS_ENABLED=false
EVAL_TARGET_MODEL=gpt-5.4-mini-2026-03-17
EVAL_REASONING_EFFORT=low
EVAL_DEFAULT_REPETITIONS=2
EVAL_CANARY_REPETITIONS=1
EVAL_CANARY_CASES_PER_AGENT=5
EVAL_COST_HARD_LIMIT_USD=50
EVAL_MAX_CONCURRENCY=1
EVAL_MAX_RETRIES=1
EVAL_REQUEST_TIMEOUT_MS=60000
EVAL_MAX_PROVIDER_REQUESTS=50
EVAL_MAX_OUTPUT_TOKENS_ITEM_VERIFICATION=3000
EVAL_MAX_OUTPUT_TOKENS_RESPONSE_COLLECTION=1500
EVAL_MAX_OUTPUT_TOKENS_PROFILING=4000
EVAL_MAX_OUTPUT_TOKENS_PLANNING=3000
EVAL_MAX_OUTPUT_TOKENS_FOLLOWUP=2500

# Phase 7E2B guarded full live evaluation pilot defaults.
# Pilot live calls are CLI-only and separate from classroom live calls.
# Leave disabled unless intentionally running the paid 100-output pilot locally.
EVAL_PILOT_PROVIDER=openai
EVAL_PILOT_LIVE_CALLS_ENABLED=false
EVAL_PILOT_APPROVED_CANARY_RUN_ID=
EVAL_PILOT_TARGET_MODEL=gpt-5.4-mini-2026-03-17
EVAL_PILOT_REASONING_EFFORT=low
EVAL_PILOT_REPETITIONS=2
EVAL_PILOT_INTERNAL_HOLDOUT_CASES_PER_AGENT=5
EVAL_PILOT_REPLICATION_CASES_PER_AGENT=5
EVAL_PILOT_COST_HARD_LIMIT_USD=50
EVAL_PILOT_MAX_PROVIDER_REQUESTS=150
EVAL_PILOT_MAX_CONCURRENCY=1
EVAL_PILOT_MAX_RETRIES=1
EVAL_PILOT_REQUEST_TIMEOUT_MS=60000

# Phase 7E2C targeted remediation regression defaults.
# Uses the same eval provider enablement and exact model snapshot as live eval,
# but has its own smaller budget and request guard.
EVAL_TARGETED_REMEDIATION_COST_HARD_LIMIT_USD=10
EVAL_TARGETED_REMEDIATION_MAX_PROVIDER_REQUESTS=35
EVAL_TARGETED_REMEDIATION_MAX_CONCURRENCY=1
EVAL_TARGETED_REMEDIATION_MAX_RETRIES=1
EVAL_TARGETED_REMEDIATION_REQUEST_TIMEOUT_MS=60000

# Student browser process-event thresholds for local development.
# These are technical debounce/timing defaults, not psychological thresholds.
NEXT_PUBLIC_LONG_PAUSE_MS=120000
NEXT_PUBLIC_INACTIVITY_MS=300000
