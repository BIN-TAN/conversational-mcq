  uploaded_by User       @relation("McqItemImportUploader", fields: [uploaded_by_user_db_id], references: [id], onDelete: Restrict)

  @@index([assessment_db_id, created_at])
  @@index([uploaded_by_user_db_id, created_at])
  @@index([status, created_at])
  @@map("mcq_item_import_batches")
}

model StudentAccountEvent {
  id                        String                  @id @default(uuid()) @db.Uuid
  event_public_id           String                  @unique @default(cuid())
  student_user_db_id        String                  @db.Uuid
  performed_by_user_db_id   String                  @db.Uuid
  event_type                StudentAccountEventType
  roster_import_batch_db_id String?                 @db.Uuid
  metadata                  Json
  created_at                DateTime                @default(now()) @db.Timestamptz(6)

  student             User               @relation("StudentAccountEvents", fields: [student_user_db_id], references: [id], onDelete: Restrict)
  performed_by        User               @relation("StudentAccountEventPerformer", fields: [performed_by_user_db_id], references: [id], onDelete: Restrict)
  roster_import_batch RosterImportBatch? @relation(fields: [roster_import_batch_db_id], references: [id], onDelete: SetNull)

  @@index([student_user_db_id, created_at])
  @@index([performed_by_user_db_id, created_at])
  @@index([roster_import_batch_db_id])
  @@index([event_type, created_at])
  @@map("student_account_events")
}

model StudentAccountDeletionEvent {
  id                       String   @id @default(uuid()) @db.Uuid
  event_public_id          String   @unique @default(cuid())
  student_user_id_snapshot String
  performed_by_user_db_id  String   @db.Uuid
  deletion_summary         Json
  created_at               DateTime @default(now()) @db.Timestamptz(6)

  performed_by User @relation("StudentAccountDeletionEventPerformer", fields: [performed_by_user_db_id], references: [id], onDelete: Restrict)

  @@index([student_user_id_snapshot, created_at])
  @@index([performed_by_user_db_id, created_at])
  @@map("student_account_deletion_events")
}

model AssessmentDeletionEvent {
  id                            String   @id @default(uuid()) @db.Uuid
  deletion_public_id            String   @unique @default(cuid())
  deleted_assessment_public_id  String
  deleted_assessment_public_hash String
  assessment_title_snapshot     String
  performed_by_user_db_id       String   @db.Uuid
  deletion_mode                 String
  deletion_summary              Json
  created_at                    DateTime @default(now()) @db.Timestamptz(6)

  performed_by User @relation("AssessmentDeletionEventPerformer", fields: [performed_by_user_db_id], references: [id], onDelete: Restrict)

  @@index([deleted_assessment_public_id, created_at])
  @@index([performed_by_user_db_id, created_at])
  @@index([deletion_mode, created_at])
  @@map("assessment_deletion_events")
}

model ExportJob {
  id                      String          @id @default(uuid()) @db.Uuid
  export_public_id        String          @unique @default(cuid())
  requested_by_user_db_id String          @db.Uuid
  status                  ExportJobStatus @default(pending)
  file_name               String?
  storage_key             String?
  row_count               Int?
  options                 Json?
  export_schema_version   String?
  created_at              DateTime        @default(now()) @db.Timestamptz(6)
  completed_at            DateTime?       @db.Timestamptz(6)
  expires_at              DateTime?       @db.Timestamptz(6)
  error_message           String?         @db.Text

  requested_by User @relation("ExportJobRequester", fields: [requested_by_user_db_id], references: [id], onDelete: Restrict)

  @@index([requested_by_user_db_id, created_at])
  @@index([status])
  @@index([expires_at])
  @@map("export_jobs")
}
