generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  student
  teacher_researcher
}

enum UserAccountStatus {
  active
  inactive
}

enum AssessmentStatus {
  draft
  published
  archived
}

enum AssessmentWorkflowMode {
  manual_review
  automatic
}

enum ResponseCollectionMode {
  deterministic
  llm_assisted
}

enum ConceptUnitStatus {
  draft
  published
  archived
}

enum ItemStatus {
  draft
  published
  archived
}

enum ItemMediaPlacement {
  item_stem
  option
}

enum ItemMediaType {
  image
  video
  reference_link
}

enum ItemMediaSourceType {
  uploaded
  external_url
}

enum AssessmentPhase {
  not_started
  session_started
  concept_unit_intro
  initial_item_administration
  missing_evidence_repair
  initial_concept_unit_completed
  profiling_pending
  profiling_completed
  planning_pending
  planning_completed
  followup_active
  followup_profile_update_pending
  followup_planning_update_pending
  followup_stopped
  between_concept_units
  session_completed
  student_exited
  needs_review
}

enum SessionStatus {
  not_started
  active
  paused
  completed
  student_exited
  needs_review
}

enum ConceptUnitSessionStatus {
  not_started
  initial_in_progress
  initial_completed
  followup_active
  followup_completed
  completed
  student_exited
  needs_review
}

enum FollowupStatus {
  not_started
  active
  stopped
  completed
  incomplete
  needs_review
}

enum ResponseCorrectness {
  not_scored
  correct
  incorrect
  unanswered
}

enum ConfidenceLevel {
  low
  medium
  high
}

enum ActorType {
  student
  agent
  system
  orchestrator
  teacher_researcher
}

enum EventSource {
  frontend
  backend
  agent
  system
}

enum WorkflowJobType {
  run_initial_profiling
  run_initial_planning
  start_initial_followup
  run_followup_profile_update
  run_followup_planning_update
  finalize_followup_update
  finalize_concept_progression
}

enum WorkflowJobStatus {
  pending
  running
  retryable
  completed
  failed
  cancelled
}

enum WorkflowOverrideActionType {
  pause_automation
  resume_automation
  retry_current_step
  stop_followup
}

enum AgentCallStatus {
  started
  succeeded
  failed
  invalid_output
  needs_review
}

enum ProfileType {
  initial
  updated
}

enum AbilityProfile {
  insufficient_evidence
  minimal_or_no_demonstrated_understanding
  fragmented_or_limited_understanding
  partial_understanding
  misconception_based_understanding
  fragile_correct_understanding
  procedural_or_application_error
  mostly_correct_understanding
  robust_transfer_ready_understanding
}

enum EngagementProfile {
  insufficient_process_evidence
  low_engagement
  variable_engagement
  adequate_engagement
  productive_engagement
  sustained_high_engagement
}

enum IntegratedDiagnosticProfile {
  insufficient_evidence_for_formative_decision
  low_engagement_limits_interpretability
  conflicting_evidence_needs_clarification
  developing_understanding_with_productive_engagement
  misconception_with_sufficient_engagement
  correct_but_fragile_understanding
  correct_but_independence_uncertain
  underconfident_but_reasoning_supported
  robust_understanding_ready_for_transfer
}

enum EvidenceSufficiency {
  insufficient
  limited
  adequate
  strong
}

enum ConfidenceAlignment {
  insufficient_evidence
  underconfident
  well_calibrated
  overconfident
  mixed
}

enum IndependenceInterpretability {
  not_applicable
  independent_understanding_likely
  independent_understanding_uncertain
  insufficient_evidence
}

enum FormativeValue {
  diagnostic_clarification
  reasoning_refinement
  confidence_calibration
  independent_understanding_verification
  consolidation_or_transfer
}

enum FollowupRoundStatus {
  not_started
  active
  completed
  stopped
  needs_review
}

enum FollowupUpdateCycleStatus {
  pending
  profiling
  profiling_completed
  planning
  planning_completed
  opening
  committing
  completed
  failed
  cancelled
}

enum FollowupUpdateTriggerType {
  agent_evidence_candidate
  reasoning_revision
  task_completion
  transfer_application
  understanding_claim
  move_on_request
  substantive_turn_threshold
  student_stop_final_update
  student_progression_final_update
  teacher_manual
}

enum FollowupUpdatePostCycleAction {
  none
  advance_to_next_concept
  complete_assessment
}

enum ConceptProgressionType {
  next_concept
  complete_assessment
}

enum ConceptProgressionTriggerType {
  robust_profile
  agent_move_on_offer
  student_move_on_request
  student_explicit_button
}

enum ConceptProgressionStudentChoice {
  continue_current_concept
  next_concept
  stay_in_final_concept
  complete_assessment
}

enum ConceptProgressionStatus {
  offered
  final_update_pending
  evaluating_resolution
  awaiting_unresolved_confirmation
  progressing
  completed
  cancelled
  failed
}

enum ConceptProgressionResolutionStatus {
  resolved
  unresolved
  unknown
}

enum ExportJobStatus {
  pending
  processing
  completed
  failed
  expired
}

enum SummativeOutcomeImportStatus {
  previewed
  committed
  failed
  cancelled
}

enum SummativeOutcomeRecordStatus {
  active
  superseded
}

enum RosterImportStatus {
  previewed
  committed
  failed
  cancelled
}

enum StudentAccountEventType {
  student_created_manually
  student_created_by_roster
  display_name_updated
  access_code_reset
  student_deactivated
  student_reactivated
  teacher_student_account_created
  teacher_student_password_reset
  teacher_student_deactivated
  teacher_student_reactivated
  student_password_changed
}

enum ItemVerificationRunStatus {
  pending
  completed
  failed
  stale
}

enum EvalCaseSource {
  synthetic
  teacher_authored
  deidentified
}

enum EvalRunMode {
  mock
  imported_output
  live_provider
}

enum EvalRecordStatus {
  active
  archived
}

enum EvalRunStatus {
  pending
  running
  paused
  budget_unverifiable
  completed
  failed
}

model User {
  id                    String            @id @default(uuid()) @db.Uuid
  user_id               String            @unique
  user_id_normalized    String            @unique
  display_name          String?
  email                 String?
  role                  UserRole
  password_hash         String?
  access_code_hash      String?
  account_status        UserAccountStatus @default(active)
  auth_version          Int               @default(1)
  must_change_password  Boolean           @default(false)
  deactivated_at        DateTime?         @db.Timestamptz(6)
  credential_updated_at DateTime?         @db.Timestamptz(6)
  credential_reset_at   DateTime?         @db.Timestamptz(6)
  password_changed_at   DateTime?         @db.Timestamptz(6)
  last_login_at         DateTime?         @db.Timestamptz(6)
  created_by_teacher_user_id String?      @db.Uuid
  created_at            DateTime          @default(now()) @db.Timestamptz(6)
  updated_at            DateTime          @updatedAt @db.Timestamptz(6)

  created_assessments                       Assessment[]                  @relation("AssessmentCreator")
  assessment_sessions                       AssessmentSession[]
  summative_outcomes                        SummativeOutcome[]            @relation("SummativeOutcomeStudent")
  uploaded_summative_outcomes               SummativeOutcome[]            @relation("SummativeOutcomeUploader")
  uploaded_summative_outcome_import_batches SummativeOutcomeImportBatch[] @relation("SummativeOutcomeImportUploader")
  export_jobs                               ExportJob[]                   @relation("ExportJobRequester")
  workflow_overrides_created                WorkflowOverride[]            @relation("WorkflowOverrideCreator")
  uploaded_roster_import_batches            RosterImportBatch[]           @relation("RosterImportUploader")
  uploaded_mcq_item_import_batches          McqItemImportBatch[]          @relation("McqItemImportUploader")
  student_account_events                    StudentAccountEvent[]         @relation("StudentAccountEvents")
  performed_student_account_events          StudentAccountEvent[]         @relation("StudentAccountEventPerformer")
  performed_student_account_deletion_events StudentAccountDeletionEvent[] @relation("StudentAccountDeletionEventPerformer")
  performed_assessment_deletion_events      AssessmentDeletionEvent[]     @relation("AssessmentDeletionEventPerformer")
  acknowledged_item_verification_runs       ItemVerificationRun[]         @relation("ItemVerificationAcknowledgement")
  created_eval_suites                       EvalSuite[]                   @relation("EvalSuiteCreator")
  created_eval_runs                         EvalRun[]                     @relation("EvalRunCreator")
  eval_annotations                          EvalAnnotation[]              @relation("EvalAnnotationAuthor")
  confirmed_eval_annotations                EvalAnnotation[]              @relation("EvalAnnotationConfirmer")
  amended_eval_annotation_revisions         EvalAnnotationRevision[]      @relation("EvalAnnotationRevisionAmender")

  @@index([email])
  @@index([created_by_teacher_user_id])
  @@map("users")
}

model Assessment {
  id                       String                 @id @default(uuid()) @db.Uuid
  assessment_public_id     String                 @unique @default(cuid())
  title                    String
  description              String?                @db.Text
  diagnostic_focus         String?                @db.Text
  folder_label             String?
  folder_order_index       Int                    @default(0)
  assessment_order_index   Int                    @default(0)
  status                   AssessmentStatus       @default(draft)
  workflow_mode            AssessmentWorkflowMode @default(automatic)
  response_collection_mode ResponseCollectionMode @default(llm_assisted)
  release_at               DateTime?              @db.Timestamptz(6)
  close_at                 DateTime?              @db.Timestamptz(6)
  created_by_user_db_id    String                 @db.Uuid
  created_at               DateTime               @default(now()) @db.Timestamptz(6)
  updated_at               DateTime               @updatedAt @db.Timestamptz(6)

  created_by          User                @relation("AssessmentCreator", fields: [created_by_user_db_id], references: [id], onDelete: Restrict)
  concept_units       ConceptUnit[]
  assessment_sessions AssessmentSession[]
  mcq_item_import_batches McqItemImportBatch[]

  @@index([created_by_user_db_id])
  @@index([status])
  @@index([workflow_mode])
  @@index([response_collection_mode])
  @@index([folder_label])
  @@index([folder_order_index, assessment_order_index])
  @@index([release_at])
  @@index([close_at])
  @@map("assessments")
}

model ConceptUnit {
  id                                 String            @id @default(uuid()) @db.Uuid
  concept_unit_public_id             String            @unique @default(cuid())
  assessment_db_id                   String            @db.Uuid
  title                              String
  learning_objective                 String            @db.Text
  related_concept_description        String            @db.Text
  administration_rules               Json?
  order_index                        Int
  status                             ConceptUnitStatus @default(draft)
  version                            Int               @default(1)
  latest_item_verification_run_db_id String?           @db.Uuid
  created_at                         DateTime          @default(now()) @db.Timestamptz(6)
  updated_at                         DateTime          @updatedAt @db.Timestamptz(6)

  assessment                      Assessment                 @relation(fields: [assessment_db_id], references: [id], onDelete: Restrict)
  items                           Item[]
  latest_item_verification_run    ItemVerificationRun?       @relation("LatestItemVerificationRun", fields: [latest_item_verification_run_db_id], references: [id], onDelete: SetNull)
  item_verification_runs          ItemVerificationRun[]      @relation("ConceptUnitItemVerifications")
  assessment_sessions_current     AssessmentSession[]        @relation("CurrentConceptUnit")
  concept_unit_sessions           ConceptUnitSession[]
  destination_progression_records ConceptProgressionRecord[] @relation("DestinationConceptUnitProgression")

  @@unique([assessment_db_id, order_index])
  @@index([assessment_db_id, status])
  @@index([assessment_db_id, order_index])
  @@index([latest_item_verification_run_db_id])
  @@map("concept_units")
}

model Item {
  id                                String     @id @default(uuid()) @db.Uuid
  item_public_id                    String     @unique @default(cuid())
  concept_unit_db_id                String     @db.Uuid
  item_order                        Int
  item_stem                         String     @db.Text
  options                           Json
  correct_option                    String
  distractor_rationales             Json?
  expected_reasoning_patterns       Json?
  possible_misconception_indicators Json?
  administration_rules              Json?
  included_in_published_set         Boolean    @default(true)
  status                            ItemStatus @default(draft)
  version                           Int        @default(1)
  created_at                        DateTime   @default(now()) @db.Timestamptz(6)
  updated_at                        DateTime   @updatedAt @db.Timestamptz(6)

  concept_unit       ConceptUnit        @relation(fields: [concept_unit_db_id], references: [id], onDelete: Restrict)
  media_assets       ItemMediaAsset[]
  item_responses     ItemResponse[]
  conversation_turns ConversationTurn[]
  process_events     ProcessEvent[]

  @@unique([concept_unit_db_id, item_order])
  @@index([concept_unit_db_id, status])
  @@index([concept_unit_db_id, item_order])
  @@map("items")
}

model ItemMediaAsset {
  id                            String              @id @default(uuid()) @db.Uuid
  media_public_id               String              @unique @default(cuid())
  item_db_id                    String              @db.Uuid
  option_label                  String?
  placement                     ItemMediaPlacement
  media_type                    ItemMediaType
  source_type                   ItemMediaSourceType
  storage_key                   String?
  public_or_signed_url          String?             @db.Text
  external_url                  String?             @db.Text
  title                         String?
  alt_text_or_description       String              @db.Text
  student_alt_text              String?             @db.Text
  teacher_llm_media_description String?             @db.Text
  caption                       String?             @db.Text
  transcript_or_content_summary String?             @db.Text
  source_attribution            String?             @db.Text
  media_context_hash            String
  order_index                   Int                 @default(0)
  active                        Boolean             @default(true)
  media_version                 Int                 @default(1)
  created_at                    DateTime            @default(now()) @db.Timestamptz(6)
  updated_at                    DateTime            @updatedAt @db.Timestamptz(6)

  item Item @relation(fields: [item_db_id], references: [id], onDelete: Cascade)

  @@index([item_db_id, active, order_index])
  @@index([media_type])
  @@index([source_type])
  @@map("item_media_assets")
}

model AssessmentSession {
  id                                String                 @id @default(uuid()) @db.Uuid
  session_public_id                 String                 @unique @default(cuid())
  user_db_id                        String                 @db.Uuid
  assessment_db_id                  String                 @db.Uuid
  attempt_number                    Int                    @default(1)
  status                            SessionStatus          @default(not_started)
  current_phase                     AssessmentPhase        @default(not_started)
  workflow_mode_snapshot            AssessmentWorkflowMode @default(manual_review)
  response_collection_mode_snapshot ResponseCollectionMode @default(deterministic)
  current_concept_unit_db_id        String?                @db.Uuid
  resume_phase                      AssessmentPhase?
  resume_context                    Json?
  needs_review                      Boolean                @default(false)
  needs_review_reason               String?                @db.Text
  automation_paused_at              DateTime?              @db.Timestamptz(6)
  automation_exception_reason       String?                @db.Text
  started_at                        DateTime?              @db.Timestamptz(6)
  last_activity_at                  DateTime?              @db.Timestamptz(6)
  completed_at                      DateTime?              @db.Timestamptz(6)
  created_at                        DateTime               @default(now()) @db.Timestamptz(6)
  updated_at                        DateTime               @updatedAt @db.Timestamptz(6)

  user                            User                          @relation(fields: [user_db_id], references: [id], onDelete: Restrict)
  assessment                      Assessment                    @relation(fields: [assessment_db_id], references: [id], onDelete: Restrict)
  current_concept_unit            ConceptUnit?                  @relation("CurrentConceptUnit", fields: [current_concept_unit_db_id], references: [id], onDelete: SetNull)
  concept_unit_sessions           ConceptUnitSession[]
  conversation_turns              ConversationTurn[]
  process_events                  ProcessEvent[]
  agent_calls                     AgentCall[]
  student_action_idempotency_keys StudentActionIdempotencyKey[]
  workflow_jobs                   WorkflowJob[]
  workflow_overrides              WorkflowOverride[]
  followup_update_cycles          FollowupUpdateCycle[]
  concept_progression_records     ConceptProgressionRecord[]

  @@unique([user_db_id, assessment_db_id, attempt_number])
  @@index([user_db_id, status])
  @@index([assessment_db_id, status])
  @@index([status, current_phase])
  @@index([workflow_mode_snapshot, current_phase])
  @@index([response_collection_mode_snapshot, current_phase])
  @@index([current_concept_unit_db_id])
  @@map("assessment_sessions")
}

model ConceptUnitSession {
  id                              String                   @id @default(uuid()) @db.Uuid
  assessment_session_db_id        String                   @db.Uuid
  concept_unit_db_id              String                   @db.Uuid
  status                          ConceptUnitSessionStatus @default(not_started)
  initial_started_at              DateTime?                @db.Timestamptz(6)
  initial_completed_at            DateTime?                @db.Timestamptz(6)
  followup_started_at             DateTime?                @db.Timestamptz(6)
  followup_completed_at           DateTime?                @db.Timestamptz(6)
  followup_status                 FollowupStatus           @default(not_started)
  followup_round_count            Int                      @default(0)
  latest_student_profile_db_id    String?                  @db.Uuid
  latest_formative_decision_db_id String?                  @db.Uuid
  created_at                      DateTime                 @default(now()) @db.Timestamptz(6)
  updated_at                      DateTime                 @updatedAt @db.Timestamptz(6)

  assessment_session          AssessmentSession          @relation(fields: [assessment_session_db_id], references: [id], onDelete: Restrict)
  concept_unit                ConceptUnit                @relation(fields: [concept_unit_db_id], references: [id], onDelete: Restrict)
  latest_student_profile      StudentProfile?            @relation("LatestStudentProfile", fields: [latest_student_profile_db_id], references: [id], onDelete: SetNull)
  latest_formative_decision   FormativeDecision?         @relation("LatestFormativeDecision", fields: [latest_formative_decision_db_id], references: [id], onDelete: SetNull)
  item_responses              ItemResponse[]
  conversation_turns          ConversationTurn[]
  process_events              ProcessEvent[]
  agent_calls                 AgentCall[]
  response_packages           ResponsePackage[]
  student_profiles            StudentProfile[]           @relation("ConceptUnitSessionProfiles")
  formative_decisions         FormativeDecision[]        @relation("ConceptUnitSessionFormativeDecisions")
  followup_rounds             FollowupRound[]
  workflow_jobs               WorkflowJob[]
  workflow_overrides          WorkflowOverride[]
  followup_update_cycles      FollowupUpdateCycle[]
  concept_progression_records ConceptProgressionRecord[]

  @@unique([assessment_session_db_id, concept_unit_db_id])
  @@index([assessment_session_db_id, status])
  @@index([concept_unit_db_id])
  @@index([latest_student_profile_db_id])
  @@index([latest_formative_decision_db_id])
  @@map("concept_unit_sessions")
}

model ItemResponse {
  id                              String              @id @default(uuid()) @db.Uuid
  concept_unit_session_db_id      String              @db.Uuid
  item_db_id                      String              @db.Uuid
  selected_option                 String?
  correct_option_snapshot         String
  correctness                     ResponseCorrectness @default(not_scored)
  reasoning_text                  String?             @db.Text
  confidence_rating               ConfidenceLevel?
  item_response_time_ms           Int?
  item_started_at                 DateTime?           @db.Timestamptz(6)
  item_submitted_at               DateTime?           @db.Timestamptz(6)
  skipped_reasoning               Boolean             @default(false)
  skipped_confidence              Boolean             @default(false)
  skipped_item                    Boolean             @default(false)
  revision_count                  Int                 @default(0)
  missing_evidence_repair_offered Boolean             @default(false)
  item_version_snapshot           Int
  item_snapshot                   Json
  client_submission_id            String?
  created_at                      DateTime            @default(now()) @db.Timestamptz(6)
  updated_at                      DateTime            @updatedAt @db.Timestamptz(6)

  concept_unit_session ConceptUnitSession @relation(fields: [concept_unit_session_db_id], references: [id], onDelete: Restrict)
  item                 Item               @relation(fields: [item_db_id], references: [id], onDelete: Restrict)

  @@unique([concept_unit_session_db_id, item_db_id])
  @@unique([concept_unit_session_db_id, client_submission_id])
  @@index([item_db_id])
  @@index([item_submitted_at])
  @@map("item_responses")
}

model StudentActionIdempotencyKey {
  id                       String   @id @default(uuid()) @db.Uuid
  assessment_session_db_id String   @db.Uuid
  client_action_id         String
  action_type              String
  request_hash             String
  response_payload         Json?
  created_at               DateTime @default(now()) @db.Timestamptz(6)
  updated_at               DateTime @updatedAt @db.Timestamptz(6)

  assessment_session AssessmentSession @relation(fields: [assessment_session_db_id], references: [id], onDelete: Restrict)

  @@unique([assessment_session_db_id, client_action_id])
  @@index([assessment_session_db_id, action_type])
  @@map("student_action_idempotency_keys")
}

model ConversationTurn {
  id                         String          @id @default(uuid()) @db.Uuid
  assessment_session_db_id   String          @db.Uuid
  concept_unit_session_db_id String?         @db.Uuid
  item_db_id                 String?         @db.Uuid
  followup_round_db_id       String?         @db.Uuid
  phase                      AssessmentPhase
  actor_type                 ActorType
  agent_name                 String?
  message_text               String?         @db.Text
  structured_payload         Json?
  created_at                 DateTime        @default(now()) @db.Timestamptz(6)

  assessment_session                         AssessmentSession     @relation(fields: [assessment_session_db_id], references: [id], onDelete: Restrict)
  concept_unit_session                       ConceptUnitSession?   @relation(fields: [concept_unit_session_db_id], references: [id], onDelete: Restrict)
  item                                       Item?                 @relation(fields: [item_db_id], references: [id], onDelete: Restrict)
  followup_round                             FollowupRound?        @relation(fields: [followup_round_db_id], references: [id], onDelete: Restrict)
  evidence_cutoff_for_followup_update_cycles FollowupUpdateCycle[] @relation("FollowupUpdateEvidenceCutoff")

  @@index([assessment_session_db_id, created_at])
  @@index([concept_unit_session_db_id, created_at])
  @@index([item_db_id])
  @@index([followup_round_db_id])
  @@map("conversation_turns")
}

model ProcessEvent {
  id                         String      @id @default(uuid()) @db.Uuid
  assessment_session_db_id   String      @db.Uuid
  concept_unit_session_db_id String?     @db.Uuid
  item_db_id                 String?     @db.Uuid
  event_type                 String
  event_category             String
  event_source               EventSource
  visibility_duration_ms     Int?
  pause_duration_ms          Int?
  payload                    Json?
  occurred_at                DateTime    @db.Timestamptz(6)
  created_at                 DateTime    @default(now()) @db.Timestamptz(6)

  assessment_session   AssessmentSession   @relation(fields: [assessment_session_db_id], references: [id], onDelete: Restrict)
  concept_unit_session ConceptUnitSession? @relation(fields: [concept_unit_session_db_id], references: [id], onDelete: Restrict)
  item                 Item?               @relation(fields: [item_db_id], references: [id], onDelete: Restrict)

  @@index([assessment_session_db_id, occurred_at])
  @@index([concept_unit_session_db_id, occurred_at])
  @@index([assessment_session_db_id, event_type, occurred_at])
  @@index([event_type])
  @@index([item_db_id])
  @@map("process_events")
}

model WorkflowJob {
  id                         String            @id @default(uuid()) @db.Uuid
  job_public_id              String            @unique @default(cuid())
  job_type                   WorkflowJobType
  status                     WorkflowJobStatus @default(pending)
  assessment_session_db_id   String            @db.Uuid
  concept_unit_session_db_id String?           @db.Uuid
  idempotency_key            String            @unique
  payload                    Json
  attempt_count              Int               @default(0)
  max_attempts               Int               @default(3)
  run_after                  DateTime          @default(now()) @db.Timestamptz(6)
  locked_at                  DateTime?         @db.Timestamptz(6)
  locked_by                  String?
  last_error_category        String?
  last_error_message         String?           @db.Text
  created_at                 DateTime          @default(now()) @db.Timestamptz(6)
  updated_at                 DateTime          @updatedAt @db.Timestamptz(6)
  completed_at               DateTime?         @db.Timestamptz(6)

  assessment_session   AssessmentSession   @relation(fields: [assessment_session_db_id], references: [id], onDelete: Restrict)
