[
  {
    "case_id": "iva_clean_item_set_001",
    "agent_name": "item_verification_agent",
    "title": "Clean item set",
    "description": "Synthetic item set expected to pass without warnings.",
    "input_payload": {
      "concept_unit": {
        "concept_unit_public_id": "eval_cu_patterns",
        "title": "Recognizing Patterns",
        "learning_objective": "Identify a rule from simple evidence.",
        "related_concept_description": "Students compare examples and infer a general rule.",
        "version": 1
      },
      "items": [
        {
          "item_public_id": "eval_item_patterns_1",
          "item_order": 1,
          "item_stem": "A sequence adds 3 each step: 4, 7, 10. Which value comes next?",
          "options": [
            { "label": "A", "text": "13" },
            { "label": "B", "text": "12" },
            { "label": "C", "text": "14" }
          ],
          "correct_option": "A",
          "distractor_rationales": {
            "B": "Adds 2 instead of 3.",
            "C": "Adds 4 instead of 3."
          },
          "expected_reasoning_patterns": ["Identify the constant increase of 3."],
          "possible_misconception_indicators": ["Treats the increase as changing."],
          "version": 1
        },
        {
          "item_public_id": "eval_item_patterns_2",
          "item_order": 2,
          "item_stem": "Which statement best describes the pattern 2, 4, 8, 16?",
          "options": [
            { "label": "A", "text": "Each term doubles." },
            { "label": "B", "text": "Each term adds 2." },
            { "label": "C", "text": "Each term triples." }
          ],
          "correct_option": "A",
          "distractor_rationales": {
            "B": "Applies only from 2 to 4.",
            "C": "Confuses multiplication rules."
          },
          "expected_reasoning_patterns": ["Compare ratios between terms."],
          "possible_misconception_indicators": ["Uses only the first difference."],
          "version": 1
        }
      ],
      "verification_constraints": {
        "advisory_only": true,
        "teacher_final_authority": true,
        "do_not_generate_or_rewrite_content": true,
        "deterministic_validation_already_passed": true,
        "no_student_data_in_input": true
      }
    },
    "expected_output_shape": { "verification_status": "verified_no_warnings" },
    "gold_labels": { "mock_mode": "item_verification_no_warnings", "expected_issue_code": null },
    "rubric_expectations": { "must_not_rewrite": true, "should_flag_issue": false },
    "safety_expectations": { "no_student_data": true, "no_content_generation": true },
    "notes": "Synthetic Phase 7E1 fixture."
  },
